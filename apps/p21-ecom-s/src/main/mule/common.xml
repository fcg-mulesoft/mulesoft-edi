<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:os="http://www.mulesoft.org/schema/mule/os"
	xmlns:http="http://www.mulesoft.org/schema/mule/http"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/os http://www.mulesoft.org/schema/mule/os/current/mule-os.xsd">
	<sub-flow name="systemApiGetOautTokenSubFlow" doc:id="fcecdcf9-7454-48c3-bff2-4418a7aa0ce8" >
		<os:contains doc:name="Contains" doc:id="4279e693-5188-451a-9292-2bf8f1a71149" key="token" objectStore="Object_store" target="storeContains"/>
		<choice doc:name="Choice" doc:id="f4cc2ab5-a097-4451-9519-fda3bdf23d33" >
			<when expression="#[vars.storeContains == true]">
				<os:retrieve doc:name="Retrieve" doc:id="1abdffb0-881e-4701-9b9b-0e6161bb21c6" key="token" objectStore="Object_store" target="authToken"/>
			</when>
			<otherwise >
				<logger level="DEBUG" doc:name="Before Token Request Logger" doc:id="64754ed7-2d6a-4bf7-8bf7-6d0c4ba541a6" message="#[import p from Mule&#10;output application/json&#10;---&#10;&#10;{&#10;	&quot;message&quot;:&quot;Begin P21 auth token request.&quot;,&#10;	&quot;tracePoint&quot;: &quot;BEFORE_REQUEST&quot;,&#10;	&quot;correlationId&quot;: correlationId,&#10;	&quot;details&quot;: &quot;tokenRequestUrl: HTTPS://&quot; ++ p('P21api.host') ++ &quot;:&quot; ++ p('P21api.port') ++ p('P21api.tokenRequestUrl') ++ &quot;username:&quot; ++ p('P21api.username'),&#10;}]"/>
				<http:request method="POST" doc:name="P21tokenRequest" doc:id="65ca8df2-772b-47c7-b816-2efc7ae7359c" path="${P21api.tokenPath}" sendCorrelationId="AUTO" config-ref="callReq_configuration" target="authToken">
			<http:query-params><![CDATA[#[output application/java
---
{
	"username" : p('P21api.username'),
	"password" : p('secure::P21api.password')
}]]]></http:query-params>
		</http:request>
				<!-- <set-variable value="#[payload]" doc:name="authToken" doc:id="3811ed63-10bc-421a-a1fb-154cf814244d" variableName="authToken"/> -->
				<logger level="DEBUG" doc:name="After Token Request Logger" doc:id="6b545bde-b4ab-4514-8389-db0a0eeb49e8" message='#[%dw 2.0 &#10;output application/json&#10;---&#10;&#10;{&#10;	"message":"End P21 auth token request.",&#10;	"tracePoint": "AFTER_REQUEST",&#10;	"correlationId": correlationId,&#10;	"authToken": vars.authToken&#10;}]'/>
				<os:store doc:name="Store" doc:id="10b1a951-cdcb-4b33-b935-8ee92b8cdb58" key="token" objectStore="Object_store">
					<os:value ><![CDATA[#[vars.authToken]]]></os:value>
				</os:store>
			

</otherwise>
		</choice>
	
</sub-flow>
</mule>
