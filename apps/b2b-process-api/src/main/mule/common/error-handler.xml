	<error-handler name="global-common-error-handler" doc:id="563d1b3b-156b-4772-9049-db788b4f5a22" >
		<on-error-propagate enableNotifications="true" logException="true" doc:name="APIKIT Errors" doc:id="82c2498d-bd1d-4f2c-9254-df285235de7e" when='#[error.errorType.namespace == "APIKIT"]' >
			<logger level="ERROR" doc:name="LOG INFO: Start Flow" doc:id="29aa0212-9fc3-4882-b859-0b3820d235dd" message="Start: Global Error Handler: APIKIT ERROR" />
			<ee:transform doc:name="var : httpStatus" doc:id="d2ced819-650a-41d1-9e7a-d49e17a17b3d" >
				<ee:message />
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_apikit_httpStatus.dwl" variableName="httpStatus" />
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="var : errorResponse, systemInformation" doc:id="f60132e4-2d52-4a08-b986-e14009dc412d" >
				<ee:message />
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_apikit_errorResponse.dwl" variableName="errorResponse" />
					<ee:set-variable resource="dwl/global-common-error-handler/v_systemInformation.dwl" variableName="systemInformation" />
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="Preparing Email Template, var : subject, vendorName" doc:id="143a87a8-7576-459e-a83c-da2e9799eef8" >
				<ee:message >
					<ee:set-payload resource="dwl/global-common-error-handler/generic-error-handling.dwl" />
				</ee:message>
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_subject.dwl" variableName="subject" />
					<ee:set-variable variableName="vendorName" ><![CDATA[%dw 2.0
output application/json
---
[(p('partner.inbound.' ++ (vars.initialPayload[0].b2bMessage.header.senderId default "" as String)))]
    default [(p('partner.outbound.' ++ (vars.initialPayload[0].b2bMessage.header.senderId default "" as String)))]
    default []]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<flow-ref doc:name="send-email-subflow" doc:id="7e864436-5ddc-425c-bf59-6c7fdca79205" name="send-email-subflow" />
			<set-payload value="#[vars.errorResponse]" doc:name="Set Payload : Response" doc:id="625e87af-ab15-4102-8983-89ca716bd3fe" />
			<logger level="INFO" doc:name="LOG INFO: End Flow" doc:id="73163ab8-3614-4bbf-8510-0e8a9073bd9e" message="#[vars.errorResponse]" category="com.apikit.errors" />
		</on-error-propagate>
		<on-error-propagate enableNotifications="true" logException="true" doc:name="Validation Errors" doc:id="a601a7a2-dc1a-4ce9-8506-a09fb11a77df" when='#[error.errorType.namespace == "CUSTOM" and error.errorType.identifier == "VALIDATION_FAILED"]' >
			<logger level="ERROR" doc:name="LOG INFO: Start Flow" doc:id="be42c555-389e-4df8-af9e-d68dc8131be4" message="Start: Global Error Handler: Validation ERROR" />
			<ee:transform doc:name="var : errorResponse, systemInformation" doc:id="0fe78c76-40dc-49cc-bdb9-e5822b6435db" >
				<ee:message />
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_systemInformation.dwl" variableName="systemInformation" />
					<ee:set-variable resource="dwl/global-common-error-handler/v_validation_errorResponse.dwl" variableName="errorResponse" />
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="Preparing Email Template, var : subject, vendorName, errorDetails" doc:id="4b8c9eee-c577-4e31-b34f-616940708899" >
				<ee:message >
					<ee:set-payload resource="dwl/global-common-error-handler/generic-error-handling.dwl" />
				</ee:message>
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_subject.dwl" variableName="subject" />
					<ee:set-variable variableName="vendorName" ><![CDATA[%dw 2.0
output application/json
---
[(p('partner.inbound.' ++ (vars.initialPayload[0].b2bMessage.header.senderId default "" as String)))]
    default [(p('partner.outbound.' ++ (vars.initialPayload[0].b2bMessage.header.senderId default "" as String)))]
    default []]]></ee:set-variable>
					<ee:set-variable variableName="errorDetails" ><![CDATA[%dw 2.0
output application/json
---
{
	"errorNs": "CUSTOM",
	"errorId": "VALIDATION"
}]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<flow-ref doc:name="send-email-subflow" doc:id="144558c7-be6f-49eb-98e4-9caa6759d351" name="send-email-subflow" />
			<set-payload value="#[vars.errorResponse]" doc:name="Set Payload : Response" doc:id="5672a066-16ba-4471-8f94-eb012128e6c2" />
			<logger level="INFO" doc:name="LOG INFO: End Flow" doc:id="27ab5599-dbb2-421e-979f-6588da106524" message="#[vars.errorResponse]" category="com.validation.errors" />
		</on-error-propagate>
		<on-error-propagate enableNotifications="true" logException="true" doc:name="Generic" doc:id="f2bc8bc0-ab29-40ea-befa-e0fbc0b4dfeb" >
			<logger level="ERROR" doc:name="LOG INFO: Start Flow" doc:id="21c33efb-40b1-4fdd-be2f-516a188f28bd" message="Start: Global Error Handler: GENERIC ERROR" />
			<ee:transform doc:name="var : httpStatus" doc:id="e67d7838-9b51-4a48-9958-d03aa11914f8" >
				<ee:message />
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_generic_httpStatus.dwl" variableName="httpStatus" />
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="var : errorResponse, systemInformation" doc:id="14711625-d3fb-47a5-9b2c-5be74c48ba89" >
				<ee:message />
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_systemInformation.dwl" variableName="systemInformation" />
					<ee:set-variable resource="dwl/global-common-error-handler/v_generic_errorResponse.dwl" variableName="errorResponse" />
				</ee:variables>
			</ee:transform>
			<ee:transform doc:name="Preparing Email Template, var : subject, vendorName" doc:id="19891363-12ef-4b1b-b67a-13897b04726c" >
				<ee:message >
					<ee:set-payload resource="dwl/global-common-error-handler/generic-error-handling.dwl" />
				</ee:message>
				<ee:variables >
					<ee:set-variable resource="dwl/global-common-error-handler/v_subject.dwl" variableName="subject" />
					<ee:set-variable variableName="vendorName" ><![CDATA[%dw 2.0
output application/json
---
[(p('partner.inbound.' ++ (vars.initialPayload[0].b2bMessage.header.senderId default "" as String)))]
    default [(p('partner.outbound.' ++ (vars.initialPayload[0].b2bMessage.header.senderId default "" as String)))]
    default []]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<flow-ref doc:name="send-email-subflow" doc:id="8fd93da9-3e91-4035-8982-cb383a55b653" name="send-email-subflow" />
			<set-payload value="#[vars.errorResponse]" doc:name="Set Payload : Response" doc:id="0390dd71-edff-45a7-a939-f8474b412637" />
			<logger level="INFO" doc:name="LOG INFO: End Flow" doc:id="89f50ea4-a10b-4545-a8f5-6dabc5d74d1e" message="#[vars.errorResponse]" category="com.generic.errors" />
		</on-error-propagate>
	</error-handler>
	<sub-flow name="send-email-subflow" doc:id="bb5f38c4-af63-4c8e-9f45-75a1361f4932" >
		<logger level="DEBUG" doc:name="LOG DEBUG: Before Email" doc:id="a2e7fd31-6339-4cd9-b6c5-4a5f53d547c3" message="Start: Email Alert" />
		<flow-ref doc:name="Flow Reference To get-email-view-subflow" doc:id="86810691-d6cf-4bce-a9de-552c668d8ef7" name="get-email-view-subflow" target="emailView" />
		<ee:transform doc:name="var : emailList" doc:id="1af8eb63-3c31-4b05-97fd-3a06334ac05c" >
			<ee:message />
			<ee:variables >
				<ee:set-variable variableName="emailList" ><![CDATA[%dw 2.0

output application/java
 
var viewRecords =

    (vars.emailView.value default [])

        filter ((vars.vendorName default []) contains $.trading_partner_name)
 
---

{

    to:

        (

            viewRecords flatMap ((record) ->

                [

                    record.fcg_biz_contact_email,

                    record.fcg_tech_contact_email,

                    record.trading_partner_contact_email

                ]

            )

        )

        filter ($ != null and trim($) != "")

        distinctBy ((item) -> item)

}
 ]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<until-successful maxRetries="5" doc:name="Until Successful" doc:id="f351731c-a4e3-43cf-ba09-c67b2a80eb69" millisBetweenRetries="6000" >
			<try doc:name="Try" doc:id="d4f777ff-8a5e-45e1-867b-d294c268f813" >
				<choice doc:name="If transmissionId Exists?" doc:id="3f9ce635-e367-4b01-930a-a3b23f80795b" >
					<when expression="#[!isEmpty(vars.initialPayload[0].b2bMessage.header.transmissionId)]" >
						<idempotent-message-validator doc:name="To Avoid Duplicate Emails" doc:id="3315a843-1f2b-40a2-966d-6e8d25ad981f" idExpression="#[vars.initialPayload[0].b2bMessage.header.transmissionId]" objectStore="Object_store" />
					</when>
				</choice>
				<email:send doc:name="Send Email" doc:id="a68cd7fb-b878-4ce2-8355-31a5d941fd50" config-ref="Email_SMTP" fromAddress="${email.username}" subject="#[vars.subject]" toAddresses="#[vars.emailList.&quot;to&quot; ++ (Mule::p('email.toRecipient') splitBy (&quot;,&quot;))]" >
					<reconnect />
					<email:body contentType="text/html" />
				</email:send>
				<error-handler >
					<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="075d8785-265b-403c-9a7e-8388a777f2b0" type="DUPLICATE_MESSAGE" >
						<logger level="INFO" doc:name="LOG INFO : Duplicate Error - Skipping Email" doc:id="82417a66-a9b9-4acb-aeef-b5695e968fea" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	flow: flow.name,&#10;	timestamp: now(),&#10;	message: "Duplicate Error - Skipping Email"&#10;}]' />
					</on-error-continue>
				</error-handler>
			</try>
		</until-successful>
		<logger level="DEBUG" doc:name="LOG DEBUG: After Email" doc:id="9747b797-85c2-4157-8b85-810d180ba3ee" message="End: Email Alert" />
	</sub-flow>
</mule>
