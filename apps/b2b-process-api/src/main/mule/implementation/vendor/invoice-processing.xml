<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">
	<sub-flow name="inbound-invoice-processing-subflow" doc:id="0f3b0ec8-ab83-4254-a92f-ce1b7e4e5fca" >
		<logger level="INFO" doc:name="LOG INFO : START" doc:id="f3eaae67-8060-4585-9b21-8949893def16" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "Start: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]'/>
		<ee:transform doc:name="var : httpOperation - get purchase order" doc:id="0f587fa5-6fc6-4c33-aa38-3c2478ca3fe8" >
			<ee:message >
			</ee:message>
			<ee:variables >
				<ee:set-variable variableName="httpOperation" ><![CDATA[%dw 2.0
output application/json
import toBase64 from dw::core::Binaries
---
{
    "method": "GET",
    "host": Mule::p('b2b-p21-sys-api.host'),
    "port": Mule::p('b2b-p21-sys-api.port'),
    "basePath": Mule::p('b2b-p21-sys-api.basePath'),
    "path": Mule::p('b2b-p21-sys-api.view.path'),
    "headers":{
    	"client_id": "1234",
    	"client_secret": "1234"
    },
	"queryParams":{
		"transactionType": "purchaseOrderInvoice",
		"purpose": "validation",
		"businesskey": vars.initialPayload.b2bMessage.header.purchaseOrderNumber[0]
    },
    "uriParams": {
    },
    "untilsuccessful":{
    	"maxRetries": "3",
    	"interval": "5000"
    }
}]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<flow-ref doc:name="Flow Reference To commom-http-request-subflow" doc:id="fe068a4b-652e-4c31-a9e9-4aac018cbed3" name="common-http-request-subflow" target="purchaseOrderData"/>
		<ee:transform doc:name="var : isValid" doc:id="866e5918-c2cb-45fd-b79c-fddd23c0c465" >
			<ee:message >
			</ee:message>
			<ee:variables >
				<ee:set-variable resource="dwl/inbound-invoice-processing-subflow/v_isValid.dwl" variableName="isValid" />
			</ee:variables>
		</ee:transform>
		<choice doc:name="isValid Invoice?" doc:id="79afbb3c-188a-4276-acd4-2c9d7bb69503">
			<when expression="#[vars.isValid.isValid == false]">
				<raise-error doc:name="CUSTOM:VALIDATION_FAILED" doc:id="7ead687f-13fd-40c6-87a7-c586405347d4" type="CUSTOM:VALIDATION_FAILED" description="Validation Failed" />
			</when>
			<otherwise>
				<logger level="INFO" doc:name="LOG INFO : Valid Invoice" doc:id="5f5af8b4-e52c-4e60-850d-cde8a78887e3" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"flow": (flow.name),&#10;	"message": "Invoice validation successful, Moving forward to create the invoice in p21",&#10;    "correlationId": correlationId&#10;}]' />
			</otherwise>
		</choice>
		<ee:transform doc:name="var : p21Invoice" doc:id="4dc242d7-5131-44a4-a93a-f72e5a3cc70d" >
			<ee:message >
			</ee:message>
			<ee:variables >
				<ee:set-variable resource="dwl/inbound-invoice-processing-subflow/v_p21Invoice.dwl" variableName="p21Invoice" />
			</ee:variables>
		</ee:transform>
		<ee:transform doc:name="var : httpOperation - post invoice" doc:id="8d832f08-d5bd-4035-bb98-a4041efdda0c">
			<ee:message />
			<ee:variables>
				<ee:set-variable variableName="httpOperation"><![CDATA[%dw 2.0
output application/json
import toBase64 from dw::core::Binaries
---
{
    "method": "POST",
    "host": Mule::p('b2b-p21-sys-api.host'),
    "port": Mule::p('b2b-p21-sys-api.port'),
    "basePath": Mule::p('b2b-p21-sys-api.basePath'),
    "path": Mule::p('b2b-p21-sys-api.transaction.path'),
    "headers":{
    	"client_id": "1234",
    	"client_secret": "1234"
    },
	"queryParams":{
		"transactionType": "purchaseOrderInvoice",
    },
    "uriParams": {
    },
    "untilsuccessful":{
    	"maxRetries": "5",
    	"interval": "5000"
    },
    "body": vars.p21Invoice
}]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<flow-ref doc:name="Flow Reference To commom-http-request-subflow" doc:id="98913654-3e07-4c01-be00-d71faa614beb" name="common-http-request-subflow" />
		<choice doc:name="is Successful?" doc:id="4a8c246b-d93e-451f-afbd-f3e1e84a071b" >
			<when expression='#[(payload.Results.Transactions[0]."Status" == "Failed")]'>
				<raise-error doc:name="CUSTOM:P21_FAILED" doc:id="cf33fd6d-514a-40df-8113-45bedd343499" type="CUSTOM:P21_FAILED" description='#[payload.Messages joinBy ","]'/>
			</when>
			<otherwise >
				<logger level="INFO" doc:name="LOG INFO : InvoiceCreated" doc:id="a929f772-d691-425a-abf8-8333ff62d353" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"flow": (flow.name),&#10;	"message": "Invoice Creation Successful",&#10;    "correlationId": correlationId&#10;}]'/>
			</otherwise>
		</choice>
		<logger level="INFO" doc:name="LOG INFO : END" doc:id="7a218d2e-888d-442d-8952-b5cdd14450e9" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "End: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]'/>
	</sub-flow>
</mule>
