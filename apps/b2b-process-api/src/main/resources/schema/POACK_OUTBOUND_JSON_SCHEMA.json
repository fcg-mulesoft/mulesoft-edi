{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["b2bMessage"],
  "additionalProperties": false,
  "properties": {
    "b2bMessage": {
      "type": "object",
      "required": [
        "header",
        "detail",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "header": {
          "type": "object",
          "required": [
            "senderId",
            "receiverId",
            "acknowledgmentPurposeCode",
            "acknowledgmentType",
            "acknowledgementdate",
            "purchaseOrderNumber",
            "purchaseOrderDate",
            "sellerOrderNumber",
            "partyInformation"
          ],
          "additionalProperties": false,
          "properties": {
            "senderId": {
              "type": "string"
            },
            "receiverId": {
              "type": "string"
            },
            "acknowledgmentPurposeCode": {
              "type": "string",
              "enum": [
                "00",
                "01",
                "04",
                "06",
                "16",
                "19"
              ]
            },
            "acknowledgmentType": {
              "type": "string",
              "enum": [
                "AC",
                "AD",
                "AE",
                "AH",
                "AK",
                "AT",
                "RD",
                "RF",
                "RJ",
                "ZZ"
              ]
            },
            "purchaseOrderNumber": {
              "type": "string",
              "minLength": 1
            },
            "purchaseOrderDate": {
              "type": "string",
              "pattern": "^[0-9]{8}$"
            },
            "acknowledgementdate": {
              "type": "string",
              "pattern": "^[0-9]{8}$"
            },
            "sellerOrderNumber": {
              "type": "string"
            },
            "references": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "qualifier",
                  "referenceNumber"
                ],
                "additionalProperties": false,
                "properties": {
                  "qualifier": {
                    "type": "string"
                  },
                  "referenceNumber": {
                    "type": "string"
                  }
                }
              }
            },
            "dates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "qualifier",
                  "date"
                ],
                "additionalProperties": false,
                "properties": {
                  "qualifier": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string",
                    "pattern": "^[0-9]{8}$"
                  }
                }
              }
            },
            "partyInformation": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "qualifier",
                  "name"
                ],
                "additionalProperties": false,
                "properties": {
                  "qualifier": {
                    "type": "string",
                    "enum": [
                      "VN",
                      "SF",
                      "ST",
                      "BY",
                      "BT"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "idQualifier": {
                    "type": "string",
                    "enum": [
                      "92"
                    ]
                  },
                  "idCode": {
                    "type": "string"
                  },
                  "address1": {
                    "type": "string"
                  },
                  "city": {
                    "type": "string"
                  },
                  "state": {
                    "type": "string"
                  },
                  "postalCode": {
                    "type": "string"
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "idQualifier"
                      ]
                    },
                    "then": {
                      "required": [
                        "idCode"
                      ]
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "idCode"
                      ]
                    },
                    "then": {
                      "required": [
                        "idQualifier"
                      ]
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "state"
                      ]
                    },
                    "then": {
                      "required": [
                        "city"
                      ]
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "postalCode"
                      ]
                    },
                    "then": {
                      "required": [
                        "city",
                        "state"
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "detail": {
          "type": "object",
          "required": [
            "lineItems"
          ],
          "additionalProperties": false,
          "properties": {
            "lineItems": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "lineNo",
                  "qty",
                  "uom",
                  "unitPrice",
                  "acknowledgments"
                ],
                "additionalProperties": false,
                "properties": {
                  "lineNo": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "qty": {
                    "type": "number",
                    "minimum": 0
                  },
                  "uom": {
                    "type": "string"
                  },
                  "unitPrice": {
                    "type": "number",
                    "minimum": 0
                  },
                  "priceQualifier": {
                    "type": "string"

                  },
                  "buyerPartQualifier": {
                    "type": "string"
                  },
                  "buyerPartNo": {
                    "type": "string"
                  },
                  "vendorPartQualifier": {
                    "type": "string"
                  },
                  "vendorPartNo": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "productDescriptions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "descriptionType",
                        "description"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "descriptionType": {
                          "type": "string",
                          "enum": [
                            "F"
                          ]
                        },
                        "description": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "acknowledgments": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": [
                        "statusCode",
                        "quantity",
                        "uom"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "statusCode": {
                          "type": "string",
                          "enum": [
                            "IA",
                            "IC",
                            "IR"
                          ]
                        },
                        "quantity": {
                          "type": "number",
                          "minimum": 0
                        },
                        "uom": {
                          "type": "string"
                        },
                        "dateQualifier": {
                          "type": "string"
                        },
                        "date": {
                          "type": "string",
                          "pattern": "^[0-9]{8}$"
                        }
                      },
                      "allOf": [
                        {
                          "if": {
                            "required": [
                              "dateQualifier"
                            ]
                          },
                          "then": {
                            "required": [
                              "date"
                            ]
                          }
                        },
                        {
                          "if": {
                            "required": [
                              "date"
                            ]
                          },
                          "then": {
                            "required": [
                              "dateQualifier"
                            ]
                          }
                        }
                      ]
                    }
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "buyerPartQualifier"
                      ]
                    },
                    "then": {
                      "required": [
                        "buyerPartNo"
                      ]
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "buyerPartNo"
                      ]
                    },
                    "then": {
                      "required": [
                        "buyerPartQualifier"
                      ]
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "vendorPartQualifier"
                      ]
                    },
                    "then": {
                      "required": [
                        "vendorPartNo"
                      ]
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "vendorPartNo"
                      ]
                    },
                    "then": {
                      "required": [
                        "vendorPartQualifier"
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "summary": {
          "type": "object",
          "required": [
            "totalLineItems"
          ],
          "additionalProperties": false,
          "properties": {
            "totalLineItems": {
              "type": "integer",
              "minimum": 1
            },
            "totalAcknowledgedQuantity": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}