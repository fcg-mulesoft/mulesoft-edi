{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["B2BMessage"],
  "properties": {
    "B2BMessage": {
      "type": "object",
      "required": ["Header", "detail", "Summary"],
      "properties": {
        "Header": {
          "type": "object",
          "required": [
            "senderId",
            "receiverId",
            "purchaseOrderNumber",
            "purchaseOrderDate",
            "purchaseOrderTypeCode",
            "partyInformation"
          ],
          "properties": {
            "senderId": { "type": "string" },
            "receiverId": { "type": "string" },
            "purchaseOrderNumber": { "type": "string" },
            "purchaseOrderDate": {
              "type": "string"
            },
            "purchaseOrderType": { "type": "string" },
            "purchaseOrderTypeCode": { "type": "string" },
            "currencyCode": { "type": "string" },

            "contacts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "contactFunction": { "type": "string" },
                  "name": { "type": "string" },
                  "commNumberQualifier": { "type": "string" },
                  "commNumber": { "type": "string" }
                }
              }
            },

            "dates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dateQualifier": { "type": "string" },
                  "date": {
                    "type": "string",
                    "pattern": "^[0-9]{8}$"
                  }
                }
              }
            },

            "carrier": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["scac"],
                "properties": {
                  "scac": { "type": "string" },
                  "routing": { "type": "string" }
                }
              }
            },

            "references": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "qualifier": { "type": "string" },
                  "referenceNumber": { "type": "string" }
                }
              }
            },

            "partyInformation": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "qualifier",
                  "name",
                  "idQualifier",
                  "idCode"
                ],
                "properties": {
                  "qualifier": {
                    "type": "string",
                    "enum": ["BY", "ST", "SU", "BT"]
                  },
                  "name": { "type": "string" },
                  "idQualifier": { "type": "string" },
                  "idCode": { "type": "string" },
                  "address1": { "type": "string" },
                  "city": { "type": "string" },
                  "state": { "type": "string" },
                  "postalCode": { "type": "string" },
                  "country": { "type": "string" },

                  "references": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "qualifier": { "type": "string" },
                        "referenceNumber": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },

        "detail": {
          "type": "object",
          "required": ["lineItems"],
          "properties": {
            "lineItems": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "lineNo",
                  "qtyOrdered",
                  "uom",
                  "unitPrice",
                  "vendorPartNo"
                ],
                "properties": {
                  "lineNo": { "type": "integer" },
                  "qtyOrdered": { "type": "number" },
                  "uom": { "type": "string" },
                  "unitPrice": { "type": "number" },
                  "priceQualifier": { "type": "string" },

                  "vendorPartNumberQualifier": { "type": "string" },
                  "vendorPartNo": { "type": "string" },

                  "buyerPartNumberQualifier": { "type": "string" },
                  "buyerPartNo": { "type": "string" },

                  "productDescription": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["description"],
                      "properties": {
                        "descriptionType": { "type": "string" },
                        "description": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },

        "Summary": {
          "type": "object",
          "required": ["totalLineItems"],
          "properties": {
            "totalLineItems": { "type": "integer" },
            "totalQuantity": { "type": "number" }
          }
        }
      }
    }
  }
}