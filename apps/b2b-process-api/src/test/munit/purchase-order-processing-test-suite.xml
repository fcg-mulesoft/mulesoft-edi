			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock Http Request: send email" doc:id="ee311d2f-9085-4ce1-adb4-c98105b21fce" processor="flow-ref">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="send-email-subflow" attributeName="doc:name" />
				</munit-tools:with-attributes>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="994cc14a-3370-46e2-9ee1-983c73e4d7f9" >
				<munit:payload value="#[readUrl('classpath://dwl/purchase-order-processing-test-suite/payload.dwl')]" encoding="UTF-8" mediaType="application/json" />
				<munit:variables >
					<munit:variable key="purchaseOrderData" value="#[output json ---readUrl('classpath://dwl/purchase-order-processing-test-suite/payload.dwl')]" encoding="UTF-8" mediaType="application/json" />
				</munit:variables>
			</munit:set-event>
			<flow-ref doc:name="Flow-ref to purchase-order-processing-subflow" doc:id="311e3c4d-70a3-4709-996c-604293f50ff3" name="purchase-order-processing-subflow"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:verify-call doc:name="Verify call" doc:id="1d36eade-015b-4d09-9995-371a096c7942" processor="logger">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="LOG INFO : END" attributeName="doc:name" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
