	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="invoice-processing-test-suite.xml" />
	<munit:test name="inbound-invoice-processing-subflowTest" doc:id="aa4ab2ac-1331-42c2-8c91-a21bcb699cef" description="Test">
		<munit:behavior >
			<munit:set-event doc:name="Set Payload" doc:id="5884eb9b-bac6-4ee6-a72a-b665011c7786">
				<munit:payload value="#[%dw 2.0&#10;output application/json&#10;---&#10;readUrl('classpath://dwl/invoice-processing-test-suite/payload.dwl')]" encoding="UTF-8" mediaType="application/json" />
				<munit:attributes value="#[%dw 2.0&#10;output application/json&#10;---&#10;readUrl('classpath://dwl/invoice-processing-test-suite/attributes.dwl')]" mediaType="application/json" />
				<munit:variables >
					<munit:variable key="initialPayload" value="#[output application/json --- readUrl('classpath://dwl/invoice-processing-test-suite/payload.dwl')]" mediaType="application/json" />
				</munit:variables>
			</munit:set-event>
			<munit-tools:mock-when doc:name="Common HTTP Request" doc:id="52432169-8dac-4a5b-83fa-0cc0f3182d81" processor="http:request">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="b976f5d7-308c-4391-9d3e-e65db725d6d5" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value="#[%dw 2.0&#10;output application/json&#10;---&#10;readUrl('classpath://dwl/invoice-processing-test-suite/v_purchaseOrderData.dwl')]" mediaType="application/json" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Flow Reference To commom-http-request-subflow" doc:id="8dc865a8-4a32-40de-a0cb-8ac2d1e7d118" processor="flow-ref">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="98913654-3e07-4c01-be00-d71faa614beb" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value="#[%dw 2.0&#10;output application/json&#10;---&#10;readUrl('classpath://dwl/invoice-processing-test-suite/v_p21Response.dwl')]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<flow-ref doc:name="Flow-ref to inbound-invoice-processing-subflow" doc:id="4b4720a6-9361-4613-ac5e-5b068aa04459" name="inbound-invoice-processing-subflow"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:verify-call doc:name="LOG INFO : END" doc:id="c6f6cb7c-c7be-4dcb-b9dd-633311353448" processor="logger">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="7a218d2e-888d-442d-8952-b5cdd14450e9" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
