<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:email="http://www.mulesoft.org/schema/mule/email"
	xmlns:http="http://www.mulesoft.org/schema/mule/http"
	xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd
http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd
http://www.mulesoft.org/schema/mule/email http://www.mulesoft.org/schema/mule/email/current/mule-email.xsd">
	<sub-flow name="post-p21-transaction-xml-processing-subflow"
		doc:id="3ff36c89-ebb5-41a1-a620-7f1d9979b778">
		<logger level="INFO" doc:name="LOG INFO : START"
			doc:id="e2d859e3-1feb-4e4c-bd5a-9ce9d6a72f1a"
			message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "Start: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]' />
		<flow-ref doc:name="Flow Reference to get-oauth-token-subflow" doc:id="68a287ab-e416-4b22-bfe0-077d3e941c35" name="get-oauth-token-subflow" target="accessToken" />
		<ee:transform doc:name="var : httpOperation" doc:id="4854b613-4b83-49d7-865f-cc9022b5ec46">
			<ee:message>
			</ee:message>
			<ee:variables>
								<ee:set-variable variableName="httpOperation"><![CDATA[%dw 2.0
output application/json
var transactionType = attributes.queryParams.transactionType
var routingConfig = {
	purchaseOrder: {
		basepath: Mule::p('p21.request.basePath.sales'),
		path: Mule::p('p21.request.path.coupaOrder'),
		queryParams: {}
	},
	partsPrice: {
		basepath: Mule::p('p21.request.basePath.parts'),
		path: Mule::p('p21.request.path.partsPrices'),
		queryParams: attributes.queryParams
	}
}
var selectedConfig =
    (routingConfig[transactionType] default {
}) default {
}
---
{
    method: Mule::p('p21.request.method.transaction'),
    host: Mule::p('p21.request.host'),
    port: Mule::p('p21.request.port'),
    basePath: selectedConfig.basePath,
    path: selectedConfig.path,
    headers: {
        "Authorization": "Bearer "++ (vars.accessToken default ""),
        "Content-Type": "application/xml"
    },
    queryParams: selectedConfig.queryParams default {
	},
    uriParams: {}
}]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<flow-ref doc:name="Flow Reference to common-http-request-subflow" doc:id="924a6a48-77de-4a30-a89a-a1b281092821" name="common-http-request-subflow" />
		<ee:transform doc:name="P21 Response Payload" doc:id="42523949-c9fe-412c-ba13-f65a2cfc5e4c">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="LOG INFO : END" doc:id="78230ff4-31ad-41a0-ac88-dc3125c9f8f9" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "End: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]' />
	</sub-flow>
</mule>
