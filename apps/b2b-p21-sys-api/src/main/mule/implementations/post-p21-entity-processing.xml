<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd">

	<sub-flow name="post-p21-entity-processing-subflow"
		doc:id="c742865f-779f-44ae-b12b-bbcc07a34651">
		<logger level="INFO" doc:name="LOG INFO : START"
			doc:id="163ca55c-dc10-475d-9a88-17a38bf32dec"
			message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "Start: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]' />
		<flow-ref
			doc:name="Flow Reference to get-oauth-token-subflow"
			doc:id="39b507e3-bccc-4ce1-873d-beb855e61b73"
			name="get-oauth-token-subflow" target="accessToken" />
		<ee:transform doc:name="var : httpOperation"
			doc:id="fa2aadff-52b7-45a0-893d-a3f788c90990">
			<ee:message>
			</ee:message>
			<ee:variables>
				<ee:set-variable
					resource="dwl/post-p21-transaction-processing-subflow/v_httpOperationPostTransaction.dwl"
					variableName="httpOperation" />
				<ee:set-variable variableName="selectScript"><![CDATA[ %dw 2.0
output application/json

var transactionType = attributes.queryParams.transactionType
var checkType = attributes.queryParams.checkType default "default"
var mappingName =
    transactionType ++
    checkType ++
    ".dwl"

---
readUrl('classpath://dwl/post-p21-entity-processing-subflow/v_' ++ mappingName,'text/plain')]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<ee:dynamic-evaluate doc:name="Dynamic Evaluate"
			doc:id="43ee2fbb-3716-4670-a874-4392a1375d7f"
			expression="#[vars.selectScript]" />
		<flow-ref
			doc:name="Flow Reference to common-http-request-subflow"
			doc:id="4c273318-8cec-4374-901c-c2093c8d068e"
			name="common-http-request-subflow" />
		<ee:transform doc:name="P21 Response Payload"
			doc:id="10165467-bbd4-4fa8-b867-c2db2e6d435c">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="LOG INFO : END"
			doc:id="0a41b93b-660a-4bad-af31-ff0704464825"
			message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "End: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]' />
	</sub-flow>
</mule>
