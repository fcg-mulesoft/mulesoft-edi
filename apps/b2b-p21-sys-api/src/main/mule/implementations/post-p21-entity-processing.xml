<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">
	<sub-flow name="post-p21-entity-processing-subflow" doc:id="ad2b9f8d-da67-4827-a146-93cd5204165a" >
		<logger level="INFO" doc:name="LOG INFO : START" doc:id="1436a9ae-c7cf-47ac-9c78-818e51681e8a" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "Start: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]' />
		<flow-ref doc:name="Flow Reference to get-oauth-token-subflow" doc:id="f8287abf-5cc3-4532-869c-b1afbfbd4f5e" name="get-oauth-token-subflow" target="accessToken" />
		<ee:transform doc:name="var : httpOperation" doc:id="3e79a82e-6906-4c17-89a2-0304131172e9" >
			<ee:message >
			</ee:message>
			<ee:variables >
				<ee:set-variable resource="dwl/post-p21-transaction-processing-subflow/v_httpOperationPostTransaction.dwl" variableName="httpOperation" />
				<ee:set-variable variableName="selectScript" ><![CDATA[ %dw 2.0
output application/json

var transactionType = attributes.queryParams.transactionType
var checkType = attributes.queryParams.checkType default "default"
var mappingName =
    transactionType ++
    checkType ++
    ".dwl"

---
readUrl('classpath://dwl/post-p21-entity-processing-subflow/v_' ++ mappingName,'text/plain')]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<ee:dynamic-evaluate doc:name="Dynamic Evaluate" doc:id="bce3310e-e6f0-48ec-bb2f-74c256568ece" expression="#[vars.selectScript]"/>
		<flow-ref doc:name="Flow Reference to common-http-request-subflow" doc:id="1944d8c8-31d4-467a-a485-ddb48ad81037" name="common-http-request-subflow" />
		<ee:transform doc:name="P21 Response Payload" doc:id="c660f865-b662-4ca1-9ea7-c07d971ef4cd" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="LOG INFO : END" doc:id="234dbf4f-bf70-4468-b6f4-df5142e657de" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;	"Message": "End: " ++ (flow.name),&#10;    "correlationId": correlationId&#10;}]' />
	</sub-flow>
</mule>
