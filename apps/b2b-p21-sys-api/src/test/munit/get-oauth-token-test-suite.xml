<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="get-oauth-token-test-suite.xml" />
	<munit:test name="get-oauth-token-test-suite-get-oauth-token-subflowTest" doc:id="dc1bf887-f9cb-4694-84ba-7796d9eaa37b" description="Test">
		<munit:behavior >
			<munit-tools:mock-when doc:name="Mock Object store Contains" doc:id="0e969016-9736-4d7b-ba60-b9fc920da484" processor="os:contains">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Contains Auth Token" attributeName="doc:name" />
				</munit-tools:with-attributes>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock Object Store Retrieve" doc:id="c7f45d6f-06a5-46cf-be7e-766b141b4576" processor="os:retrieve">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="63fd4d8a-27be-411f-8884-d35d24482d42" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="16714599-97b2-4d7d-85b1-d43dda86824d" >
				<munit:variables >
					<munit:variable key="accessToken" value='"1234"' encoding="UTF-8" mediaType="application/java" />
				</munit:variables>
			</munit:set-event>
			<flow-ref doc:name="Flow-ref to get-oauth-token-subflow" doc:id="7f33a639-2619-4d26-8dd3-aad25e798c83" name="get-oauth-token-subflow"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:verify-call doc:name="Verify call" doc:id="0061416a-2897-4993-86ac-f881bb8c8ed4" processor="logger">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="9fc12cf3-a792-4560-aaeb-1da1f2bc548f" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
	</munit:test>


</mule>
